/* -------------------------------------------------------
   2. INICIALIZAÇÃO DO FIREBASE
   ------------------------------------------------------- */
firebase.initializeApp(firebaseConfig);
const db = firebase.database();

const medsRef    = db.ref('dispensador/medicamentos');
const historyRef = db.ref('dispensador/historico');
const sistemaRef = db.ref('dispensador/sistema');

// Cache local dos medicamentos
let medicationsCache = {};
let editingId        = null;
let pendingDeleteId  = null;


/* -------------------------------------------------------
   3. INICIALIZAÇÃO DA INTERFACE
   ------------------------------------------------------- */
document.addEventListener('DOMContentLoaded', () => {
  initFirebaseListeners();
  updateNextScheduleLoop();
});


/* -------------------------------------------------------
   4. LISTENERS FIREBASE — TEMPO REAL
   ------------------------------------------------------- */
function initFirebaseListeners() {

  // Monitora Medicamentos
  medsRef.on('value', (snapshot) => {
    medicationsCache = snapshot.val() || {};
    renderMedList();
    updateNextSchedule();
  });

  // Monitora Histórico (últimos 50)
  historyRef.orderByChild('timestamp').limitToLast(50).on('value', (snapshot) => {
    renderHistory(snapshot.val() || {});
  });

  // Monitora a Última Liberação vinda do ESP32
  sistemaRef.child('ultima_liberacao').on('value', (snapshot) => {
    const data = snapshot.val();
    if (data) {
      document.getElementById('lastRelease').textContent = data;
    }
  });
}


/* -------------------------------------------------------
   5. SALVAR MEDICAMENTO
   ------------------------------------------------------- */
function saveMedication() {
  const name = document.getElementById('medName').value.trim();
  const time = document.getElementById('medTime').value;
  const dose = document.getElementById('medDose').value.trim();
  const slot = parseInt(document.getElementById('medSlot').value);

  if (!name || !time || !dose) {
    showFeedback('Preencha todos os campos antes de salvar.', 'error');
    return;
  }

  const medData = { name, time, dose, slot, active: true };

  if (editingId) {
    medsRef.child(editingId).update(medData)
      .then(() => { showFeedback('Medicamento atualizado!', 'success'); cancelEdit(); })
      .catch(err => showFeedback('Erro: ' + err.message, 'error'));
  } else {
    medsRef.push(medData)
      .then(() => { showFeedback('Medicamento salvo!', 'success'); clearForm(); })
      .catch(err => showFeedback('Erro: ' + err.message, 'error'));
  }
}


/* -------------------------------------------------------
   6. EDITAR MEDICAMENTO
   ------------------------------------------------------- */
function editMedication(key) {
  const med = medicationsCache[key];
  if (!med) return;
  editingId = key;

  document.getElementById('medName').value = med.name;
  document.getElementById('medTime').value = med.time;
  document.getElementById('medDose').value = med.dose;
  document.getElementById('medSlot').value = med.slot || 1;

  document.getElementById('formTitle').textContent = 'Editar Medicamento';
  document.getElementById('cancelBtn').style.display = 'flex';
  document.getElementById('saveBtn').innerHTML =
    '<i class="fa-solid fa-floppy-disk"></i> Atualizar';

  document.querySelector('.two-col-layout').scrollIntoView({ behavior: 'smooth' });
  clearFeedback();
}

function cancelEdit() {
  editingId = null;
  clearForm();
  document.getElementById('formTitle').textContent = 'Cadastrar Medicamento';
  document.getElementById('cancelBtn').style.display = 'none';
  document.getElementById('saveBtn').innerHTML =
    '<i class="fa-solid fa-floppy-disk"></i> Salvar';
  clearFeedback();
}

function clearForm() {
  document.getElementById('medName').value = '';
  document.getElementById('medTime').value = '';
  document.getElementById('medDose').value = '';
  document.getElementById('medSlot').value = '1';
}


/* -------------------------------------------------------
   7. EXCLUIR MEDICAMENTO
   ------------------------------------------------------- */
function deleteMedication(key) {
  const med = medicationsCache[key];
  if (!med) return;
  pendingDeleteId = key;
  document.getElementById('modalMessage').textContent =
    `Deseja remover "${med.name}" (Slot ${med.slot || 1})?`;
  document.getElementById('modalConfirmBtn').onclick = confirmDelete;
  document.getElementById('modalOverlay').classList.add('active');
}

function confirmDelete() {
  medsRef.child(pendingDeleteId).remove()
    .then(() => showFeedback('Medicamento removido.', 'error'))
    .catch(err => showFeedback('Erro: ' + err.message, 'error'));
  pendingDeleteId = null;
  closeModal();
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('active');
  pendingDeleteId = null;
}

document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});


/* -------------------------------------------------------
   8. RENDERIZAR LISTA DE MEDICAMENTOS
   ------------------------------------------------------- */
function renderMedList() {
  const list       = document.getElementById('medList');
  const emptyState = document.getElementById('emptyState');

  list.innerHTML   = '';
  const keys = Object.keys(medicationsCache);

  if (keys.length === 0) {
    emptyState.style.display = 'block';
    list.style.display       = 'none';
    return;
  }

  emptyState.style.display = 'none';
  list.style.display       = 'flex';

  const sorted = keys
    .map(k => ({ key: k, ...medicationsCache[k] }))
    .sort((a, b) => a.time.localeCompare(b.time));

  sorted.forEach(med => {
    const initial  = med.name.charAt(0).toUpperCase();
    const slot     = med.slot || 1;
    const li       = document.createElement('li');
    li.className   = 'med-item';

    li.innerHTML = `
      <div class="med-avatar slot-${slot}">${initial}</div>
      <div class="med-info">
        <div class="med-name">${escapeHtml(med.name)}</div>
        <div class="med-meta">
          <span><i class="fa-solid fa-clock"></i>${formatTime(med.time)}</span>
          <span><i class="fa-solid fa-weight-scale"></i>${escapeHtml(med.dose)}</span>
          <span><i class="fa-solid fa-box"></i>Slot ${slot}</span>
        </div>
      </div>
      <span class="badge-active">Ativo</span>
      <div class="med-actions">
        <button class="btn-icon edit" title="Editar" onclick="editMedication('${med.key}')">
          <i class="fa-solid fa-pen"></i>
        </button>
        <button class="btn-icon delete" title="Excluir" onclick="deleteMedication('${med.key}')">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    `;

    list.appendChild(li);
  });
}


/* -------------------------------------------------------
   9. RENDERIZAR HISTÓRICO
   ------------------------------------------------------- */
function renderHistory(data) {
  const tbody      = document.getElementById('historyBody');
  const emptyDiv   = document.getElementById('historyEmpty');
  const wrapperDiv = document.getElementById('historyWrapper');

  tbody.innerHTML  = '';
  const entries = Object.values(data);

  if (entries.length === 0) {
    emptyDiv.style.display   = 'block';
    wrapperDiv.style.display = 'none';
    return;
  }

  emptyDiv.style.display   = 'none';
  wrapperDiv.style.display = 'block';

  entries.sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0));

  entries.forEach(entry => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><span style="font-family:'DM Mono',monospace;font-size:13px">${entry.time || '—'}</span></td>
      <td><strong>${escapeHtml(entry.medName || '—')}</strong></td>
      <td><span class="slot-badge slot-${entry.slot || 1}">Slot ${entry.slot || 1}</span></td>
      <td>${escapeHtml(entry.dose || '—')}</td>
      <td>${getBadgeHtml(entry.status)}</td>
    `;
    tbody.appendChild(tr);
  });
}

function clearHistory() {
  historyRef.remove()
    .then(() => showFeedback('Histórico limpo.', 'success'))
    .catch(err => showFeedback('Erro: ' + err.message, 'error'));
}


/* -------------------------------------------------------
   10. CÁLCULO DO PRÓXIMO HORÁRIO
   ------------------------------------------------------- */
/* -------------------------------------------------------
   10. CÁLCULO DO PRÓXIMO HORÁRIO (Lógica Corrigida)
   ------------------------------------------------------- */
/* -------------------------------------------------------
   10. CÁLCULO DO PRÓXIMO HORÁRIO (Lógica Simplificada)
   ------------------------------------------------------- */
function updateNextSchedule() {
  const keys = Object.keys(medicationsCache);
  const elNext = document.getElementById('nextSchedule');
  
  if (!elNext) return;
  if (keys.length === 0) {
    elNext.textContent = '—';
    return;
  }
  
  const now = new Date();
  // Converte a hora atual para minutos totais desde o início do dia (ex: 15:30 = 15 * 60 + 30 = 930)
  const nowMins = now.getHours() * 60 + now.getMinutes();

  const upcoming = keys
    .map(k => {
      const med = medicationsCache[k];
      const [h, min] = med.time.split(':').map(Number);
      const medMins = h * 60 + min;
      
      // Se o horário do remédio for maior que o minuto atual, ele é MAIS TARDE HOJE.
      // Se for menor ou igual, ele já passou hoje, então só vai tocar AMANHÃ (+1440 minutos).
      let diff = medMins - nowMins;
      if (diff <= 0) {
        diff += 1440; // joga para o dia seguinte
      }
      
      return { name: med.name, time: med.time, slot: med.slot || 1, diff };
    })
    // Ordena pelo que tiver a menor diferença de minutos para acontecer
    .sort((a, b) => a.diff - b.diff);

  if (upcoming.length > 0) {
    const next = upcoming[0];
    elNext.textContent = `${formatTime(next.time)} S${next.slot} — ${next.name}`;
  }
}

function updateNextScheduleLoop() {
  updateNextSchedule();
  setInterval(updateNextSchedule, 60000);
}


/* -------------------------------------------------------
   11. FUNÇÕES AUXILIARES
   ------------------------------------------------------- */
function getBadgeHtml(status) {
  switch (status) {
    case 'entregue': return `<span class="badge-entregue"><i class="fa-solid fa-check"></i> Entregue</span>`;
    case 'pendente': return `<span class="badge-pendente"><i class="fa-solid fa-clock"></i> Pendente</span>`;
    case 'falha':    return `<span class="badge-falha"><i class="fa-solid fa-xmark"></i> Falha</span>`;
    default:         return `<span>${status || '—'}</span>`;
  }
}

function formatTime(t) {
  if (!t) return '—';
  const [h, m] = t.split(':');
  return `${h.padStart(2,'0')}:${m.padStart(2,'0')}`;
}

function escapeHtml(str) {
  const map = { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#039;' };
  return String(str).replace(/[&<>"']/g, c => map[c]);
}

function showFeedback(msg, type) {
  const el = document.getElementById('formFeedback');
  el.textContent = msg;
  el.className   = `form-feedback ${type}`;
  setTimeout(clearFeedback, 3500);
}

function clearFeedback() {
  const el = document.getElementById('formFeedback');
  el.textContent = '';
  el.className   = 'form-feedback';
}